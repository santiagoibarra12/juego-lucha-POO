package modelos;

import componentes.Armadura;
import componentes.Poder;
import componentes.PoderDano;
import java.util.Random;

public abstract class Personaje {
    protected String nombre;
    protected int puntosDeVida = 100;
    protected String caracteristica;
    protected Armadura armaduraEquipada = null;
    protected Poder poderActivo = null;
    
    private final int MAX_DANO_BASE = 30;
    private final int MIN_DANO_BASE = 10;

    public void atacar(Personaje oponente) {
        Random rand = new Random();
        int danoEjecutado = rand.nextInt((MAX_DANO_BASE - MIN_DANO_BASE) + 1) + MIN_DANO_BASE;
        
        if (this.poderActivo instanceof PoderDano) {
            System.out.println("¡" + nombre + " libera su poder destructivo!");
            int bono = (int)(danoEjecutado * 0.10);
            danoEjecutado += bono;
            this.poderActivo = null; 
        }
        
        System.out.println(this.nombre + " (" + caracteristica + ") ataca a " + oponente.getNombre());
        oponente.recibirDano(danoEjecutado);
    }

    public void recibirDano(int dano) {
        int danoFinal = dano;
        if (this.armaduraEquipada != null) {
            danoFinal = dano - (int)(dano * armaduraEquipada.getPorcentajeReduccion());
            System.out.println("-> Escudo activo [" + armaduraEquipada.getRareza() + "]: Absorbió daño. Golpe final: " + danoFinal);
            this.armaduraEquipada = null; 
        }
        
        this.puntosDeVida -= danoFinal;
        if (this.puntosDeVida < 0) this.puntosDeVida = 0;
    }

    public void equiparArmadura(Armadura armadura) { this.armaduraEquipada = armadura; }
    public void activarPoder(Poder poder) { this.poderActivo = poder; }
    public boolean estaVivo() { return this.puntosDeVida > 0; }
    public String getNombre() { return this.nombre; }
    public int getPuntosDeVida() { return this.puntosDeVida; }
    public void setPuntosDeVida(int hp) { this.puntosDeVida = hp; }
    public Poder getPoderActivo() { return this.poderActivo; }
}
